# Copier ce fichier en .env.local pour surcharger localement (jamais commité, cf. .gitignore).
# Par défaut, l'API est appelée en URL relative (/api/v1) : ne pas définir cette variable
# en développement normal, le proxy Vite (vite.config.ts) redirige déjà /api vers l'API locale.
VITE_API_BASE_URL=/api/v1
